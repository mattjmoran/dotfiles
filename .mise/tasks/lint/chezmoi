#!/usr/bin/env bash
#MISE description="Validate chezmoi templates and shellcheck rendered scripts"
set -euo pipefail

# must run from the repo root
if [[ ! -d home ]]; then
  echo "lint:chezmoi: home/ source directory not found" >&2
  exit 1
fi

failed=0

# chezmoi authenticates with bitwarden when rendering templates that use it.
# removing bw from PATH makes those templates skip the call instead.
CHEZMOI=$(command -v chezmoi)
LINT_PATH=""
IFS=: read -ra dirs <<< "$PATH"
for d in "${dirs[@]}"; do [[ -x "$d/bw" ]] || LINT_PATH+="${LINT_PATH:+:}$d"; done

# mock config supplies [data] values that chezmoi init would normally prompt for
mock_dir=$(mktemp -d)
trap 'rm -rf -- "$mock_dir"' EXIT
mock_config="$mock_dir/config.toml"
cat > "$mock_config" <<'TOML'
[data]
name = "John Doe"
email = "john@example.com"
TOML

# render every template and shellcheck the ones that produce shell scripts
while IFS= read -r -d '' tmpl; do
  if ! rendered=$(PATH="$LINT_PATH" "$CHEZMOI" execute-template --config "$mock_config" --source home -f "$tmpl"); then
    echo "lint:chezmoi: $tmpl: template rendering failed" >&2
    failed=1
  # only check shell scripts that produced output
  elif [[ "$tmpl" == *.sh.tmpl && -n "$rendered" ]]; then
    if ! printf '%s\n' "$rendered" | shellcheck -; then
      echo "lint:chezmoi: $tmpl: shellcheck failed" >&2
      failed=1
    fi
  fi
done < <(find home -name '*.tmpl' -not -name '.chezmoi.toml.tmpl' -print0)

# validate the init config template with the same mock data
if ! PATH="$LINT_PATH" "$CHEZMOI" execute-template --config "$mock_config" --source home --init \
  -f home/.chezmoi.toml.tmpl >/dev/null; then
  echo "lint:chezmoi: home/.chezmoi.toml.tmpl: template rendering failed" >&2
  failed=1
fi

exit "$failed"
